      <hashTree>
        <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="build message">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="script">import java.util.concurrent.atomic.AtomicLong
import groovy.json.JsonOutput

props.putIfAbsent(&quot;msgCounter&quot;, new AtomicLong(0))
long n = ((AtomicLong) props.get(&quot;msgCounter&quot;)).incrementAndGet()
boolean head = (n % 10 != 0)
String uuid = UUID.randomUUID().toString()

vars.put(&quot;msg_uuid&quot;, uuid)
vars.put(&quot;kafkaBody&quot;, JsonOutput.toJson([msg_uuid: uuid, head: head, method: &quot;POST&quot;, uri: &quot;/post-message&quot;]))</stringProp>
        </JSR223PreProcessor>
        <hashTree/>
        <com.di.jmeter.kafka.sampler.KafkaProducerSampler guiclass="TestBeanGUI" testclass="com.di.jmeter.kafka.sampler.KafkaProducerSampler" testname="kafka message">
          <stringProp name="kafkaProducerClientVariableName">KafkaProducerClient</stringProp>
          <stringProp name="kafkaTopic">messages</stringProp>
          <stringProp name="kafkaMessageKey">${msg_uuid}</stringProp>
          <stringProp name="kafkaMessage">${kafkaBody}</stringProp>
          <stringProp name="partitionString"></stringProp>
          <collectionProp name="messageHeaders"/>
        </com.di.jmeter.kafka.sampler.KafkaProducerSampler>
        <hashTree/>
        <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer" testname="1 op/s">
          <intProp name="calcMode">0</intProp>
          <doubleProp>
            <name>throughput</name>
            <value>60.0</value>
            <savedValue>0.0</savedValue>
          </doubleProp>
        </ConstantThroughputTimer>
